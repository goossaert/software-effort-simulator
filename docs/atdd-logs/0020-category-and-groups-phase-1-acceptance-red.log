      letter-spacing: 0.01em;
    }

    header .sep { color: #4338ca; margin: 0 2px; }

    header .subtitle {
      font-size: 12px;
      color: #6366f1;
      font-weight: 400;
    }

    main {
      display: grid;
      grid-template-columns: 296px 1fr;
      overflow: hidden;
    }

    /* =====================================================
       CONFIG SIDEBAR
       ===================================================== */
    #config-panel {
      background: #1a1840;
      color: #e0e7ff;
      padding: 16px 14px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 12px;
      border-right: 1px solid #2d2b6b;
    }

    .section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #6366f1;
      padding-bottom: 5px;
      border-bottom: 1px solid #2d2b6b;
    }

    .field-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .field-group label {
      font-size: 10px;
      font-weight: 600;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.07em;
    }

    .field-group input[type=\"text\"],
    .field-group input[type=\"number\"] {
      background: #252349;
      border: 1px solid #3d3b7a;
      border-radius: 6px;
      padding: 7px 10px;
      color: #f1f5f9;
      font-size: 13px;
      width: 100%;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    .field-group input:focus {
      outline: none;
      border-color: #818cf8;
      box-shadow: 0 0 0 2px rgba(129,140,248,0.2);
    }

    /* Multi-select combo box */
    .ms-wrapper { position: relative; }
    .ms-trigger {
      display: flex; align-items: center; justify-content: space-between;
      background: #2d2b52; border: 1px solid #4a4870; border-radius: 6px;
      padding: 6px 10px; cursor: pointer; min-height: 36px; flex-wrap: wrap; gap: 4px;
    }
    .ms-trigger:hover { border-color: #7c78c0; }
    .ms-placeholder { color: #9997c0; font-size: 0.82rem; }
    .ms-arrow { color: #9997c0; font-size: 0.7rem; margin-left: 4px; flex-shrink: 0; transition: transform 0.15s; }
    .ms-wrapper.open .ms-arrow { transform: rotate(180deg); }
    .ms-chip {
      display: inline-flex; align-items: center; gap: 3px;
      background: #4a4870; color: #e2e0ff; border-radius: 4px;
      padding: 1px 6px; font-size: 0.78rem;
    }
    .ms-chip-x { cursor: pointer; opacity: 0.7; }
    .ms-chip-x:hover { opacity: 1; }
    .ms-options-wrap {
      max-height: 0; overflow: hidden; transition: max-height 0.2s ease;
      background: #2d2b52; border: 1px solid #4a4870; border-top: none;
      border-radius: 0 0 6px 6px;
    }
    .ms-wrapper.open .ms-options-wrap { max-height: 200px; overflow-y: auto; }
    .ms-option {
      display: flex; align-items: center; gap: 8px;
      padding: 6px 10px; cursor: pointer; font-size: 0.82rem; color: #c8c6f0;
    }
    .ms-option:hover { background: #3d3b62; }
    .ms-option input[type=checkbox] { accent-color: #7c78c0; }

    /* File reset row (shown below wrapper when a file is loaded) */
    .file-reset-row {
      display: flex;
      justify-content: flex-end;
      margin-top: 2px;
    }
    .file-reset-btn {
      background: none;
      border: none;
      color: #6b7280;
      font-size: 10px;
      cursor: pointer;
      padding: 0;
      letter-spacing: 0.01em;
    }
    .file-reset-btn:hover { color: #f87171; }


    /* Lognormal parameter mode selector */
    .param-mode-options {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .param-mode-options label {
      display: flex;
      align-items: flex-start;
      gap: 7px;
      font-size: 11px;
      color: #c8c6f0;
      cursor: pointer;
      padding: 5px 8px;
      border-radius: 5px;
      border: 1px solid transparent;
      transition: background 0.12s, border-color 0.12s;
    }
    .param-mode-options label input[type=radio] { margin-top: 1px; }
    .param-mode-options label:hover { background: #252349; border-color: #3d3b7a; }
    .param-mode-options label.active { background: #1e1b4b; border-color: #6366f1; }
    .param-mode-options input[type=radio] { accent-color: #6366f1; cursor: pointer; flex-shrink: 0; }
    .param-mode-note {
      font-size: 9.5px;
      color: #818cf8;
      margin-top: 1px;
      line-height: 1.3;
    }

    /* File upload widget */
    .file-upload-wrapper {
      position: relative;
      background: #252349;
      border: 1.5px dashed #3d3b7a;
      border-radius: 6px;
      padding: 8px 10px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      display: flex;
      align-items: center;
      gap: 8px;
      min-height: 36px;
    }

    .file-upload-wrapper:hover { border-color: #818cf8; background: #2d2a5a; }

    .file-upload-wrapper.loaded {
      border-color: #34d399;
      border-style: solid;
      background: #132d22;
    }

    .file-upload-wrapper .file-icon { font-size: 15px; flex-shrink: 0; }

    .file-upload-wrapper input[type=\"file\"] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%;
    }

    .file-upload-wrapper .file-name {
      font-size: 11px;
      color: #94a3b8;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .file-upload-wrapper.loaded .file-name { color: #6ee7b7; }

    /* Run button */
    #run-btn {
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 10px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.1s, box-shadow 0.15s;
      letter-spacing: 0.03em;
      width: 100%;
    }

    #run-btn:hover:not(:disabled) {
      opacity: 0.9;
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(79,70,229,0.4);
    }

    #run-btn:active:not(:disabled) { transform: translateY(0); box-shadow: none; }
    #run-btn:disabled { opacity: 0.35; cursor: not-allowed; }

    /* Data preview */
    #data-preview {
      background: #252349;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 11px;
      flex-direction: column;
      gap: 6px;
    }

    #data-preview .preview-title {
      font-size: 9px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #6366f1;
    }

    .preview-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 1px 8px;
    }

    .preview-grid .pk { color: #94a3b8; padding: 1px 0; }
    .preview-grid .pv { color: #a5f3fc; font-weight: 700; text-align: right; padding: 1px 0; }

    .preview-grid .divider {
      grid-column: 1 / -1;
      border-top: 1px solid #3d3b7a;
      margin: 4px 0;
    }

    /* Collapsible details */
    #config-panel details {
      background: #1e1c44;
      border-radius: 6px;
      border: 1px solid #2d2b6b;
      overflow: hidden;
    }

    #config-panel summary {
      cursor: pointer;
      padding: 7px 10px;
      font-size: 11px;
      color: #94a3b8;
      user-select: none;
      list-style: none;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    #config-panel summary::-webkit-details-marker { display: none; }

    #config-panel summary::before {
      content: '▶';
      font-size: 8px;
      transition: transform 0.15s;
      color: #6366f1;
    }

    #config-panel details[open] summary::before { transform: rotate(90deg); }

    #config-panel details .details-body { padding: 6px 10px 10px; }

    .size-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
    }

    .size-table th {
      color: #6366f1;
      font-weight: 600;
      text-align: left;
      padding: 3px 4px;
      border-bottom: 1px solid #3d3b7a;
    }

    .size-table td { padding: 2px 4px; color: #c7d2fe; }
    .size-table td:not(:first-child) { text-align: right; color: #94a3b8; }

    pre.debug-pre {
      font-size: 10px;
      color: #94a3b8;
      white-space: pre-wrap;
      word-break: break-all;
      line-height: 1.5;
    }

    /* =====================================================
       RESULTS PANEL
       ===================================================== */
    #results-panel {
      background: #f8fafc;
      position: relative;
      overflow-y: auto;
      padding: 24px 28px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    /* Spinner overlay */
    #spinner-overlay {
      position: absolute;
      inset: 0;
      background: rgba(248,250,252,0.9);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      z-index: 10;
      backdrop-filter: blur(2px);
    }

    #spinner-overlay p { color: #6b7280; font-size: 13px; }

    @keyframes spin { to { transform: rotate(360deg); } }

    .spinner {
      width: 44px;
      height: 44px;
      border: 4px solid #e5e7eb;
      border-top-color: #4f46e5;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }

    /* Empty state */
    #empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      gap: 14px;
      color: #9ca3af;
    }

    #empty-state .empty-icon { font-size: 52px; opacity: 0.35; }

    #empty-state p {
      font-size: 14px;
      text-align: center;
      max-width: 320px;
      line-height: 1.6;
    }

    #empty-state strong { color: #4f46e5; }

    /* Results content */
    #results-content {
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    #results-content h2 {
      font-size: 17px;
      font-weight: 700;
      color: #1e1b4b;
    }

    #results-content h2 .sub {
      font-size: 13px;
      font-weight: 400;
      color: #6b7280;
      margin-left: 8px;
    }

    /* Chart container */
    #chart-container {
      position: relative;
      height: 526px;
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 4px 12px 10px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }

    /* Stats table */
    .stats-section h3 {
      font-size: 11px;
      font-weight: 700;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 10px;
    }

    #stats-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      background: white;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }

    #stats-table th {
      padding: 10px 16px;
      text-align: left;
      font-weight: 600;
      font-size: 12px;
      color: #6b7280;
      border-bottom: 2px solid #f1f5f9;
      background: #f9fafb;
    }

    #stats-table th.col-ms  { color: #4f46e5; }
    #stats-table th.col-m   { color: #ea7c2c; }
    #stats-table th.col-msc { color: #059669; } /* emerald green — Must+Should+Could */

    #stats-table td {
      padding: 8px 16px;
      border-bottom: 1px solid #f8fafc;
      color: #374151;
    }

    #stats-table tr:last-child td { border-bottom: none; font-weight: 700; }
    #stats-table td.val { font-variant-numeric: tabular-nums; text-align: right; }

    .warn    { color: #ef4444 !important; }
    .caution { color: #f97316 !important; }
    .ok      { color: #10b981 !important; }

    /* Error state */
    .error-box {
      background: #fef2f2;
      border: 1px solid #fca5a5;
      border-radius: 8px;
      padding: 14px 16px;
      color: #b91c1c;
      font-size: 13px;
      line-height: 1.6;
    }

    /* =====================================================
       TABS
       ===================================================== */
    .tab-bar {
      display: flex;
      gap: 4px;
      border-bottom: 2px solid #e5e7eb;
      margin-bottom: 4px;
    }
    .tab-btn {
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
      padding: 7px 16px;
      font-size: 13px;
      font-weight: 600;
      color: #6b7280;
      cursor: pointer;
      border-radius: 6px 6px 0 0;
      transition: color 0.15s, border-color 0.15s;
    }
    .tab-btn:hover { color: #4f46e5; }
    .tab-btn.active { color: #4f46e5; border-bottom-color: #4f46e5; }

    /* Tab panels */
    .tab-panel { display: flex; flex-direction: column; gap: 22px; }

    /* Initiatives table */
    #initiatives-table-wrap { overflow-x: auto; }
    #initiatives-table-wrap table { border-collapse: collapse; font-size: 13px; width: 100%; }
    #initiatives-table-wrap th { background: #f1f5f9; padding: 7px 10px; text-align: left; border-bottom: 2px solid #e2e8f0; white-space: nowrap; font-weight: 600; color: #374151; }
    #initiatives-table-wrap td { padding: 5px 8px; border-bottom: 1px solid #e2e8f0; vertical-align: middle; }
    #initiatives-table-wrap tr:hover td { background: #f8fafc; }
    #initiatives-table-wrap select { font-size: 12px; border: 1px solid #d1d5db; border-radius: 4px; padding: 2px 20px 2px 6px; background: #fff; cursor: pointer; max-width: 180px; }
    #initiatives-table-wrap select:focus { outline: 2px solid #4f46e5; outline-offset: 1px; }
    .init-readonly-cell { color: #374151; font-size: 12px; }
    .initiatives-toolbar { display: flex; justify-content: flex-end; margin-bottom: 10px; }

    /* Team sections */
    #teams-container { display: flex; flex-direction: column; gap: 36px; }

    .team-section { display: flex; flex-direction: column; gap: 14px; }

    .team-section-title {
      font-size: 15px;
      font-weight: 700;
      color: #1e1b4b;
      padding-bottom: 8px;
      border-bottom: 1px solid #e5e7eb;
    }

    .team-hist-selector {
      display: flex;
      align-items: center;
      gap: 16px;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 8px 14px;
      font-size: 12px;
      color: #374151;
      flex-wrap: wrap;
      gap: 6px 16px;
    }
    .team-hist-selector .selector-label {
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      font-size: 10px;
      letter-spacing: 0.07em;
      margin-right: 4px;
    }
    .team-hist-selector label {
      display: flex;
      align-items: center;
      gap: 5px;
      cursor: pointer;
      font-size: 12px;
    }
    .team-hist-selector input[type=radio] { accent-color: #4f46e5; cursor: pointer; }
    .team-hist-rec {
      font-size: 11px;
      color: #d97706;
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-radius: 5px;
      padding: 3px 8px;
    }

    .team-chart-wrapper {
      position: relative;
      height: 420px;
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 4px 12px 10px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }

    .team-stats-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      background: white;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }
    .team-stats-table th {
      padding: 10px 16px;
      text-align: left;
      font-weight: 600;
      font-size: 12px;
      color: #6b7280;
      border-bottom: 2px solid #f1f5f9;
      background: #f9fafb;
    }
    .team-stats-table th.col-ms  { color: #4f46e5; }
    .team-stats-table th.col-m   { color: #ea7c2c; }
    .team-stats-table th.col-msc { color: #059669; }
    .team-stats-table td {
      padding: 8px 16px;
      border-bottom: 1px solid #f8fafc;
      color: #374151;
    }
    .team-stats-table tr:last-child td { border-bottom: none; font-weight: 700; }
    .team-stats-table td.val { font-variant-numeric: tabular-nums; text-align: right; }

    /* =====================================================
       TEAM PROJECTIONS TAB
       ===================================================== */

    /* MoSCoW badges — shared across projections tab */
    .mb { display:inline-block; padding:1px 7px; border-radius:4px;
          font-size:11px; font-weight:600; white-space:nowrap; }
    .mb-must     { background:#fef2f2; color:#ef4444; }
    .mb-should   { background:#fffbeb; color:#d97706; }
    .mb-could    { background:#eff6ff; color:#3b82f6; }
    .mb-wont     { background:#f9fafb; color:#9ca3af; }
    .mb-constant { background:#f0fdf4; color:#16a34a; font-size:13px; padding:1px 3px; }
    .mb-unknown { background:#f9fafb; color:#9ca3af; }
    /* ── Marker dialog ───────────────────────────────────────────── */
    .marker-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.45);
      display: none; align-items: center; justify-content: center;
      z-index: 1000;
    }
    .marker-dialog {
      background: #fff; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.22);
      width: 360px; max-width: 96vw; padding: 0; overflow: hidden;
      display: flex; flex-direction: column;
    }
    .marker-dialog-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px 12px; border-bottom: 1px solid #f1f5f9;
    }
    .marker-dialog-title { font-size: 15px; font-weight: 700; color: #1e293b; }
    .marker-close-btn {
      background: none; border: none; font-size: 20px; color: #94a3b8;
      cursor: pointer; line-height: 1; padding: 2px 6px; border-radius: 4px;
    }
    .marker-close-btn:hover { background: #f1f5f9; color: #475569; }
    .marker-dialog-body { padding: 16px 20px; display: flex; flex-direction: column; gap: 14px; }
    .marker-field-label {
      font-size: 11px; font-weight: 600; color: #6b7280; text-transform: uppercase;
      letter-spacing: 0.05em; margin-bottom: 5px;
    }
    .marker-text-input {
      width: 100%; padding: 7px 10px; border: 1.5px solid #e5e7eb; border-radius: 6px;
      font-size: 13px; color: #1e293b; box-sizing: border-box; outline: none;
    }
    .marker-text-input:focus { border-color: #6366f1; }
    .marker-text-input:disabled { background: #f9fafb; color: #9ca3af; cursor: not-allowed; }
    .color-palette-grid {
      display: grid; grid-template-columns: repeat(10, 1fr); gap: 4px;
    }
    .color-swatch {
      width: 100%; aspect-ratio: 1; border-radius: 4px; border: 2px solid transparent;
      cursor: pointer; transition: transform 0.1s, border-color 0.1s;
    }
    .color-swatch:hover { transform: scale(1.2); border-color: rgba(0,0,0,0.3); }
    .color-swatch.selected { border-color: #1e293b; transform: scale(1.15); outline: 2px solid #6366f1; outline-offset: 1px; }
    .marker-dialog-footer {
      display: flex; align-items: center; gap: 8px;
      padding: 12px 20px 16px; border-top: 1px solid #f1f5f9;
    }
    .marker-btn { padding: 7px 16px; border-radius: 6px; border: none; font-size: 13px; font-weight: 600; cursor: pointer; }
    .marker-btn-save  { background: #6366f1; color: #fff; }
    .marker-btn-save:hover  { background: #4f46e5; }
    .marker-btn-cancel { background: #f1f5f9; color: #475569; }
    .marker-btn-cancel:hover { background: #e2e8f0; }
    .marker-btn-delete { background: #fef2f2; color: #ef4444; margin-right: auto; }
    .marker-btn-delete:hover { background: #fee2e2; }
    .add-marker-btn {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 12px; border-radius: 20px; border: 1.5px dashed #c7d2fe;
      background: #eef2ff; color: #6366f1; font-size: 12px; font-weight: 600;
      cursor: pointer; transition: background 0.15s;
    }
    .add-marker-btn:hover { background: #e0e7ff; }
    .marker-stats-row td:first-child { font-size: 12px; }

    /* Count chips used in the summary table cells */
    .mc-chip { display:inline-flex; align-items:center; gap:3px;
               padding:2px 6px; border-radius:4px; font-size:10px; font-weight:600; }
    .mc-must   { background:#fef2f2; color:#ef4444; }
    .mc-should { background:#fffbeb; color:#d97706; }
    .mc-could  { background:#eff6ff; color:#3b82f6; }

    /* Summary table (teams × quarters) */
    #proj-summary-wrap { overflow-x: auto; }
    .proj-summary-table {
      width: 100%; border-collapse: collapse; font-size: 12px;
      background: white; border-radius: 8px; overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05); min-width: 600px;
    }
    .proj-summary-table th {
      padding: 8px 12px; text-align: center;
      font-weight: 600; color: #6b7280;
      border-bottom: 2px solid #f1f5f9; background: #f9fafb;
      font-size: 11px; white-space: nowrap;
    }
    .proj-summary-table th:first-child { text-align: left; min-width: 90px; }
    .proj-summary-table td {
      padding: 8px 12px; border-bottom: 1px solid #f8fafc;
      text-align: center; vertical-align: middle;
    }
    .proj-summary-table td:first-child { text-align:left; font-weight:600; color:#1e1b4b; }
    .proj-summary-table tr:last-child td { border-bottom: none; }
    .proj-cell-chips { display:flex; flex-direction:column; gap:2px; align-items:center; }

    /* Per-team projection sections */
    #proj-teams-container { display: flex; flex-direction: column; gap: 36px; }

    .proj-team-section { display: flex; flex-direction: column; gap: 14px; }

    .proj-team-title {
      font-size: 15px; font-weight: 700; color: #1e1b4b;
      padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;
    }

    .proj-charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    .proj-chart-card {
      display: flex; flex-direction: column; gap: 6px;
    }
    .proj-chart-label {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: #6b7280;
    }
    .proj-chart-wrapper {
      position: relative; height: 252px;
      background: white; border: 1px solid #e5e7eb;
      border-radius: 10px; padding: 4px 10px 8px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }

    /* Initiative matrix table */
    .proj-init-wrap { overflow-x: auto; }
    .proj-init-table {
      width: 100%; border-collapse: collapse; font-size: 12px;
      background: white; border-radius: 8px; overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }
    .proj-init-table th {
      padding: 7px 10px; text-align: left;
      font-weight: 600; font-size: 11px; color: #6b7280;
      border-bottom: 2px solid #f1f5f9; background: #f9fafb;
      white-space: nowrap;
    }
    .proj-init-table th.qcol { text-align: center; min-width: 76px; }
    .proj-init-table td {
      padding: 5px 10px; border-bottom: 1px solid #f8fafc;
      color: #374151; white-space: nowrap;
    }
    .proj-init-table td.jira-key {
      font-family: ui-monospace, monospace; font-size: 11px;
      color: #6366f1; min-width: 92px;
    }
    .proj-init-table td.init-name {
      color: #1e1b4b; max-width: 260px;
      overflow: hidden; text-overflow: ellipsis;
    }
    .proj-init-table td.moscow-td { min-width: 86px; }
    .proj-init-table td.qcol { text-align: center; }
    .proj-init-table tr:last-child td { border-bottom: none; }

    @media (max-width: 760px) {
      .proj-charts-row { grid-template-columns: 1fr; }
    }

    /* =====================================================
       RESPONSIVE
       ===================================================== */
    @media (max-width: 900px) {
      main { grid-template-columns: 260px 1fr; }
    }

    @media (max-width: 680px) {
      body { overflow: auto; }
      #app { height: auto; }
      main { grid-template-columns: 1fr; }
      #results-panel { padding: 18px; }
      #chart-container { height: 420px; }
    }
